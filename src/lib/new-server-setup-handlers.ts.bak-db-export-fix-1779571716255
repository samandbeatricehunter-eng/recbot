import {
  ActionRowBuilder,
  ButtonBuilder,
  ButtonInteraction,
  ButtonStyle,
  ChatInputCommandInteraction,
  Colors,
  EmbedBuilder,
  MessageFlags,
  ModalBuilder,
  ModalSubmitInteraction,
  PermissionFlagsBits,
  StringSelectMenuBuilder,
  StringSelectMenuInteraction,
  StringSelectMenuOptionBuilder,
  UserSelectMenuBuilder,
} from "discord.js";

import { db } from "@workspace/db";
import { leagueCommissionersTable, leagueMembersTable, seasonsTable, serverSettingsTable } from "@workspace/db";
import { and, desc, eq, sql } from "drizzle-orm";
import { WEEK_SEQUENCE, weekLabel } from "./week-helpers.js";
import { handleAdminOperationsInteraction } from "./admin-operations-handlers.js";

type SetupInteraction =
  | ButtonInteraction
  | StringSelectMenuInteraction
  | ModalSubmitInteraction;

const SETUP_PREFIX = "nss_";
const LEGACY_SETUP_PREFIX = "ns_";

const SEASON_OPTIONS = Array.from({ length: 9 }, (_, index) => {
  const value = String(index + 1);
  return new StringSelectMenuOptionBuilder()
    .setLabel(`Season ${value}`)
    .setValue(value)
    .setDefault(value === "1");
});

const SETUP_WEEK_OPTIONS = [
  new StringSelectMenuOptionBuilder()
    .setLabel("Preseason")
    .setValue("preseason"),
  ...WEEK_SEQUENCE
    .filter((week) => !week.startsWith("preseason_") && week !== "training_camp")
    .map((week) =>
      new StringSelectMenuOptionBuilder()
        .setLabel(weekLabel(week))
        .setValue(week),
    ),
];

const ADVANCE_OPTIONS = [
  { label: "24 Hours", value: "24" },
  { label: "48 Hours", value: "48" },
  { label: "72 Hours", value: "72" },
  { label: "96 Hours", value: "96" },
  { label: "Custom Hours", value: "custom" },
].map((option) =>
  new StringSelectMenuOptionBuilder()
    .setLabel(option.label)
    .setValue(option.value),
);

function flags() {
  return MessageFlags.Ephemeral;
}

function isSetupId(customId: string | undefined | null): boolean {
  return Boolean(
    customId?.startsWith(SETUP_PREFIX) ||
      customId?.startsWith(LEGACY_SETUP_PREFIX) ||
      customId === "ao_hub_back" ||
      customId === "ao_hub_close",
  );
}

export function isNewServerSetupCustomId(customId: string | undefined | null): boolean {
  return isSetupId(customId);
}

async function ensureServerSettings(guildId: string): Promise<void> {
  await db
    .insert(serverSettingsTable)
    .values({ guildId })
    .onConflictDoNothing();
}

export async function setupIsCompleted(guildId: string): Promise<boolean> {
  await ensureServerSettings(guildId);

  const [settings] = await db
    .select({ setupCompleted: serverSettingsTable.setupCompleted })
    .from(serverSettingsTable)
    .where(eq(serverSettingsTable.guildId, guildId))
    .limit(1);

  return Boolean(settings?.setupCompleted);
}

export async function userCanRunNewServerSetup(
  interaction: ChatInputCommandInteraction,
): Promise<boolean> {
  const member = interaction.guild?.members.cache.get(interaction.user.id)
    ?? await interaction.guild?.members.fetch(interaction.user.id).catch(() => null);

  return Boolean(member?.permissions.has(PermissionFlagsBits.Administrator));
}

function setupIntroEmbed(): EmbedBuilder {
  return new EmbedBuilder()
    .setColor(0xb68b2d)
    .setTitle("REC League: New Server Setup")
    .setDescription(
      [
        "This setup initializes this server for REC League operations.",
        "",
        "**1. Select Commissioners** — choose up to 6 commissioners.",
        "**2. Review/Edit Rules** — opens the structured rules manager.",
        "**3. Set Season / Week / Advance** — choose current league state.",
        "",
        "This setup is intended to be completed once per server.",
      ].join("\n"),
    );
}

function setupRows(): ActionRowBuilder<any>[] {
  const commissionerRow = new ActionRowBuilder<UserSelectMenuBuilder>().addComponents(
    new UserSelectMenuBuilder()
      .setCustomId("nss_commissioners_select")
      .setPlaceholder("Select 1-6 commissioners")
      .setMinValues(1)
      .setMaxValues(6),
  );

  const actionRow = new ActionRowBuilder<ButtonBuilder>().addComponents(
    new ButtonBuilder()
      .setCustomId("nss_rules")
      .setLabel("Review/Edit Rules")
      .setStyle(ButtonStyle.Secondary),
    new ButtonBuilder()
      .setCustomId("nss_league_settings")
      .setLabel("Set Season / Week / Advance")
      .setStyle(ButtonStyle.Primary),
  );

  return [commissionerRow, actionRow];
}

function settingsEmbed(values?: {
  seasonNumber?: number;
  currentWeek?: string;
  advanceHours?: number;
}): EmbedBuilder {
  const season = values?.seasonNumber ?? 1;
  const week = values?.currentWeek ?? "1";
  const advance = values?.advanceHours ?? 24;

  return new EmbedBuilder()
    .setColor(0xb68b2d)
    .setTitle("REC League: Season / Week / Advance")
    .setDescription(
      [
        "**Current selections**",
        `Season: **${season}**`,
        `Week: **${weekLabel(week)}**`,
        `Advance cadence: **${advance} hours**`,
        "",
        "Use the selectors below, then press **Save Setup Settings**.",
      ].join("\n"),
    );
}

function settingsRows(values?: {
  seasonNumber?: number;
  currentWeek?: string;
  advanceHours?: number;
}): ActionRowBuilder<any>[] {
  const seasonValue = String(values?.seasonNumber ?? 1);
  const weekValue = values?.currentWeek ?? "1";
  const advanceValue = String(values?.advanceHours ?? 24);

  const seasonOptions = SEASON_OPTIONS.map((option) =>
    StringSelectMenuOptionBuilder.from(option).setDefault(option.data.value === seasonValue),
  );

  const weekOptions = SETUP_WEEK_OPTIONS.map((option) =>
    StringSelectMenuOptionBuilder.from(option).setDefault(option.data.value === weekValue),
  );

  const advanceOptions = ADVANCE_OPTIONS.map((option) =>
    StringSelectMenuOptionBuilder.from(option).setDefault(option.data.value === advanceValue),
  );

  return [
    new ActionRowBuilder<StringSelectMenuBuilder>().addComponents(
      new StringSelectMenuBuilder()
        .setCustomId("nss_season_select")
        .setPlaceholder("Select season number")
        .setMinValues(1)
        .setMaxValues(1)
        .addOptions(seasonOptions),
    ),
    new ActionRowBuilder<StringSelectMenuBuilder>().addComponents(
      new StringSelectMenuBuilder()
        .setCustomId("nss_week_select")
        .setPlaceholder("Select current week")
        .setMinValues(1)
        .setMaxValues(1)
        .addOptions(weekOptions),
    ),
    new ActionRowBuilder<StringSelectMenuBuilder>().addComponents(
      new StringSelectMenuBuilder()
        .setCustomId("nss_advance_select")
        .setPlaceholder("Select advance cadence")
        .setMinValues(1)
        .setMaxValues(1)
        .addOptions(advanceOptions),
    ),
    new ActionRowBuilder<ButtonBuilder>().addComponents(
      new ButtonBuilder()
        .setCustomId("nss_save_settings")
        .setLabel("Save Setup Settings")
        .setStyle(ButtonStyle.Success),
      new ButtonBuilder()
        .setCustomId("nss_back")
        .setLabel("Back to Setup")
        .setStyle(ButtonStyle.Secondary),
    ),
  ];
}

async function currentSetupValues(guildId: string): Promise<{
  seasonNumber: number;
  currentWeek: string;
  advanceHours: number;
}> {
  await ensureServerSettings(guildId);

  const [[settings], [season]] = await Promise.all([
    db
      .select({ advanceHours: serverSettingsTable.advanceHours })
      .from(serverSettingsTable)
      .where(eq(serverSettingsTable.guildId, guildId))
      .limit(1),
    db
      .select({
        seasonNumber: seasonsTable.seasonNumber,
        currentWeek: seasonsTable.currentWeek,
      })
      .from(seasonsTable)
      .where(and(eq(seasonsTable.guildId, guildId), eq(seasonsTable.isActive, true)))
      .orderBy(desc(seasonsTable.seasonNumber))
      .limit(1),
  ]);

  return {
    seasonNumber: Math.min(9, Math.max(1, Number(season?.seasonNumber ?? 1))),
    currentWeek: String(season?.currentWeek ?? "1"),
    advanceHours: Number(settings?.advanceHours ?? 24),
  };
}

async function showSetup(interaction: SetupInteraction): Promise<void> {
  const payload = {
    embeds: [setupIntroEmbed()],
    components: setupRows(),
  };

  if (interaction.isButton() || interaction.isStringSelectMenu()) {
    await interaction.update(payload);
    return;
  }

  await interaction.reply({ ...payload, flags: flags() });
}

async function showSettings(interaction: SetupInteraction): Promise<void> {
  const guildId = interaction.guildId!;
  const values = await currentSetupValues(guildId);
  const payload = {
    embeds: [settingsEmbed(values)],
    components: settingsRows(values),
  };

  if (interaction.isButton() || interaction.isStringSelectMenu()) {
    await interaction.update(payload);
    return;
  }

  await interaction.reply({ ...payload, flags: flags() });
}

async function saveCommissioners(interaction: StringSelectMenuInteraction): Promise<void> {
  const guildId = interaction.guildId!;
  const selected = interaction.values.slice(0, 6);

  await ensureServerSettings(guildId);

  for (const discordId of selected) {
    await db
      .insert(leagueCommissionersTable)
      .values({
        guildId,
        discordId,
        role: "commissioner",
        createdBy: interaction.user.id,
      })
      .onConflictDoNothing();

    await db
      .insert(leagueMembersTable)
      .values({
        guildId,
        discordId,
        role: "commissioner",
        isCommissioner: true,
      })
      .onConflictDoUpdate({
        target: [leagueMembersTable.guildId, leagueMembersTable.discordId],
        set: {
          role: "commissioner",
          isCommissioner: true,
          updatedAt: new Date(),
        },
      });
  }

  await interaction.update({
    embeds: [
      new EmbedBuilder()
        .setColor(Colors.Green)
        .setTitle("Commissioners Saved")
        .setDescription(
          `Saved **${selected.length}** commissioner${selected.length === 1 ? "" : "s"} for this server.\n\nContinue setup below.`,
        ),
    ],
    components: setupRows(),
  });
}

async function openRulesManager(interaction: ButtonInteraction): Promise<void> {
  // Reuse the existing structured rules manager instead of opening a blank modal.
  // ao_rules is the working rules hub custom id.
  Object.defineProperty(interaction, "customId", {
    value: "ao_rules",
    configurable: true,
  });

  const handled = await handleAdminOperationsInteraction(interaction);
  if (!handled && !interaction.replied && !interaction.deferred) {
    await interaction.reply({
      content: "Could not open the rules manager.",
      flags: flags(),
    });
  }
}

async function saveSettings(interaction: ButtonInteraction): Promise<void> {
  const guildId = interaction.guildId!;
  const values = await currentSetupValues(guildId);

  if (!Number.isInteger(values.seasonNumber) || values.seasonNumber < 1 || values.seasonNumber > 9) {
    await interaction.reply({
      content: "Season must be a whole number from 1 through 9.",
      flags: flags(),
    });
    return;
  }

  if (!Number.isInteger(values.advanceHours) || values.advanceHours < 1 || values.advanceHours > 999) {
    await interaction.reply({
      content: "Advance hours must be a whole number from 1 through 999.",
      flags: flags(),
    });
    return;
  }

  await db
    .update(seasonsTable)
    .set({ isActive: false })
    .where(eq(seasonsTable.guildId, guildId));

  await db
    .insert(seasonsTable)
    .values({
      guildId,
      seasonNumber: values.seasonNumber,
      isActive: true,
      currentWeek: values.currentWeek,
    });

  await db
    .update(serverSettingsTable)
    .set({
      setupCompleted: true,
      setupCompletedAt: new Date(),
      setupCompletedBy: interaction.user.id,
      advanceHours: values.advanceHours,
      updatedAt: new Date(),
    })
    .where(eq(serverSettingsTable.guildId, guildId));

  await interaction.update({
    embeds: [
      new EmbedBuilder()
        .setColor(Colors.Green)
        .setTitle("REC Server Setup Complete")
        .setDescription(
          [
            "Server initialization is complete.",
            "",
            `Season: **${values.seasonNumber}**`,
            `Week: **${weekLabel(values.currentWeek)}**`,
            `Advance cadence: **${values.advanceHours} hours**`,
            "",
            "Next step: run the league data import.",
          ].join("\n"),
        ),
    ],
    components: [],
  });
}

function normalizeLegacyId(id: string): string {
  if (id === "ns_commissioners_select") return "nss_commissioners_select";
  if (id === "ns_edit_rules") return "nss_rules";
  if (id === "ns_rules") return "nss_rules";
  if (id === "ns_league_settings") return "nss_league_settings";
  if (id === "ns_back") return "nss_back";
  if (id === "ns_save_settings") return "nss_save_settings";
  if (id === "ns_season_select") return "nss_season_select";
  if (id === "ns_week_select") return "nss_week_select";
  if (id === "ns_advance_select") return "nss_advance_select";
  return id;
}

export async function handleNewServerSetupInteraction(
  interaction: SetupInteraction,
): Promise<boolean> {
  const originalId = interaction.customId;
  if (!isSetupId(originalId)) return false;

  if (!interaction.guildId) {
    await interaction.reply({
      content: "This setup can only be used inside a server.",
      flags: flags(),
    });
    return true;
  }

  const member = interaction.guild?.members.cache.get(interaction.user.id)
    ?? await interaction.guild?.members.fetch(interaction.user.id).catch(() => null);

  const isDiscordAdmin = member?.permissions.has(PermissionFlagsBits.Administrator) ?? false;
  if (!isDiscordAdmin) {
    await interaction.reply({
      content: "Only Discord server administrators can use server setup.",
      flags: flags(),
    });
    return true;
  }

  await ensureServerSettings(interaction.guildId);

  const id = normalizeLegacyId(originalId);

  if (id === "ao_hub_back" || id === "nss_back") {
    const completed = await setupIsCompleted(interaction.guildId);
    if (!completed) {
      await showSetup(interaction);
      return true;
    }
    return false;
  }

  if (id === "nss_commissioners_select" && interaction.isStringSelectMenu()) {
    await saveCommissioners(interaction);
    return true;
  }

  if (id === "nss_rules" && interaction.isButton()) {
    await openRulesManager(interaction);
    return true;
  }

  if (id === "nss_league_settings" && interaction.isButton()) {
    await showSettings(interaction);
    return true;
  }

  if (id === "nss_season_select" && interaction.isStringSelectMenu()) {
    const nextSeason = Number(interaction.values[0]);
    if (!Number.isInteger(nextSeason) || nextSeason < 1 || nextSeason > 9) {
      await interaction.reply({
        content: "Season must be a whole number from 1 through 9.",
        flags: flags(),
      });
      return true;
    }

    await ensureServerSettings(interaction.guildId);
    await db
      .update(serverSettingsTable)
      .set({ pendingSetupSeasonNumber: nextSeason, updatedAt: new Date() } as any)
      .where(eq(serverSettingsTable.guildId, interaction.guildId));

    const values = await currentSetupValues(interaction.guildId);
    values.seasonNumber = nextSeason;
    await interaction.update({
      embeds: [settingsEmbed(values)],
      components: settingsRows(values),
    });
    return true;
  }

  if (id === "nss_week_select" && interaction.isStringSelectMenu()) {
    const nextWeek = interaction.values[0] ?? "1";

    const allowedWeeks = new Set(["preseason", ...WEEK_SEQUENCE.filter((w) => w !== "training_camp")]);
    if (!allowedWeeks.has(nextWeek)) {
      await interaction.reply({
        content: "Invalid week selected.",
        flags: flags(),
      });
      return true;
    }

    await ensureServerSettings(interaction.guildId);
    await db
      .update(serverSettingsTable)
      .set({ pendingSetupCurrentWeek: nextWeek, updatedAt: new Date() } as any)
      .where(eq(serverSettingsTable.guildId, interaction.guildId));

    const values = await currentSetupValues(interaction.guildId);
    values.currentWeek = nextWeek;
    await interaction.update({
      embeds: [settingsEmbed(values)],
      components: settingsRows(values),
    });
    return true;
  }

  if (id === "nss_advance_select" && interaction.isStringSelectMenu()) {
    const selected = interaction.values[0] ?? "24";
    if (selected === "custom") {
      const modal = new ModalBuilder()
        .setCustomId("nss_custom_advance_modal")
        .setTitle("Custom Advance Hours");

      modal.addComponents(
        new ActionRowBuilder<any>().addComponents(
          new StringSelectMenuBuilder()
            .setCustomId("nss_unused")
            .setPlaceholder("Unused"),
        ),
      );
      // Discord modals only support text inputs.
      const fixedModal = new ModalBuilder()
        .setCustomId("nss_custom_advance_modal")
        .setTitle("Custom Advance Hours")
        .addComponents(
          new ActionRowBuilder<any>().addComponents(
            new TextInputBuilder()
              .setCustomId("advance_hours")
              .setLabel("Advance hours")
              .setStyle(1)
              .setRequired(true)
              .setMinLength(1)
              .setMaxLength(3)
              .setPlaceholder("Example: 36"),
          ),
        );

      await interaction.showModal(fixedModal);
      return true;
    }

    const nextAdvance = Number(selected);
    await db
      .update(serverSettingsTable)
      .set({ advanceHours: nextAdvance, updatedAt: new Date() })
      .where(eq(serverSettingsTable.guildId, interaction.guildId));

    const values = await currentSetupValues(interaction.guildId);
    values.advanceHours = nextAdvance;
    await interaction.update({
      embeds: [settingsEmbed(values)],
      components: settingsRows(values),
    });
    return true;
  }

  if (id === "nss_custom_advance_modal" && interaction.isModalSubmit()) {
    const raw = interaction.fields.getTextInputValue("advance_hours").trim();
    if (!/^\d+$/.test(raw)) {
      await interaction.reply({
        content: "Advance hours must be a whole number.",
        flags: flags(),
      });
      return true;
    }

    const hours = Number(raw);
    if (hours < 1 || hours > 999) {
      await interaction.reply({
        content: "Advance hours must be between 1 and 999.",
        flags: flags(),
      });
      return true;
    }

    await db
      .update(serverSettingsTable)
      .set({ advanceHours: hours, updatedAt: new Date() })
      .where(eq(serverSettingsTable.guildId, interaction.guildId));

    const values = await currentSetupValues(interaction.guildId);
    values.advanceHours = hours;

    await interaction.reply({
      embeds: [settingsEmbed(values)],
      components: settingsRows(values),
      flags: flags(),
    });
    return true;
  }

  if (id === "nss_save_settings" && interaction.isButton()) {
    await saveSettings(interaction);
    return true;
  }

  return false;
}

export function buildNewServerSetupIntro(): EmbedBuilder {
  return setupIntroEmbed();
}

export function buildNewServerSetupRows(): ActionRowBuilder<any>[] {
  return setupRows();
}

